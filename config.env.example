# Bare metal / VM / local deployment configuration
# Used by ./deploy-local.sh and docker-compose.yml (env_file).
# See docs/bare-metal.md for a full description of every field.
#
# deploy-local.sh will interactively prompt for any value left blank below
# and write the answer back into this file. Once populated, this file
# contains secrets - keep it out of version control and chmod 600.

# Host port the webhook is published on (host PORT -> container :80). The app
# always listens on :80 inside the container; a front nginx (this repo's own,
# or a sibling stack's on shared-network) reaches it at http://eka-webhook-app:80.
PORT=8080

# Public URL clients/Eka Care will reach this service on, e.g. https://webhook.example.com
EXTERNAL_URL=

# Pre-built image to run, e.g. ekacare/ekapython-webhook-sdk:v1.2.3
# (see https://hub.docker.com/repository/docker/ekacare/ekapython-webhook-sdk/general
# for available tags). Leave blank to build from the local Dockerfile instead.
# To move to a new image later: ./deploy-local.sh upgrade --image <new-ref>
# (this also updates this value for future runs).
APP_IMAGE=

# managed  - deploy-local.sh provisions nginx + certbot and terminates TLS for you
# external - you already terminate TLS yourself (own reverse proxy/load balancer);
#            deploy-local.sh only publishes PORT
SSL_MODE=external

# Ports nginx publishes on this host - only used when SSL_MODE=managed.
# HTTP_PORT must stay 80 unless something else forwards the public port 80
# to it - Let's Encrypt's HTTP-01 challenge always connects on port 80.
HTTP_PORT=80
HTTPS_PORT=443

# Which client integration to load from config.yaml (metropolis|miracles)
CLIENT_NAME=metropolis

# Registration details (required in all cases)
CLIENT_ID=YOUR_CLIENT_ID
CLIENT_SECRET=YOUR_CLIENT_SECRET
API_KEY=YOUR_API_KEY

# Generate a Signing Key (UUID). Leave blank to have deploy-local.sh generate one for you.
SIGNING_KEY=

# Messaging integrations (message_integration.py) - only required for CLIENT_NAME=metropolis
YELLOW_AI_API_KEY=YOUR_YELLOW_AI_API_KEY
JAPI_KEY=YOUR_JAPI_KEY
JAPI_AUTHORIZATION=YOUR_JAPI_AUTHORIZATION
